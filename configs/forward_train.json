{
  "seed": 42,
  "model_name": "Qwen/Qwen3-1.7B",
  "dataset_path": "artifacts/curation/curated_pairs.jsonl",
  "include_seed_dataset": false,
  "seed_dataset_name": "timdettmers/openassistant-guanaco",
  "seed_dataset_split": "train",
  "val_ratio": 0.15,
  "max_seq_length": 512,
  "max_target_tokens": 128,
  "output_dir": "artifacts/final_model_best",
  "push_to_hub": false,
  "hub_model_id": "",
  "hub_private": false,
  "show_examples": 5,
  "runtime": {
    "preferred_device": null,
    "load_in_4bit": true,
    "gradient_checkpointing": true,
    "trust_remote_code": true,
    "attn_implementation": null
  },
  "lora": {
    "r": 32,
    "alpha": 64,
    "dropout": 0.15,
    "bias": "none",
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ]
  },
  "training": {
    "num_train_epochs": 24,
    "per_device_train_batch_size": 1,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 4,
    "learning_rate": 6e-05,
    "weight_decay": 0.05,
    "warmup_ratio": 0.1,
    "lr_scheduler_type": "cosine",
    "logging_steps": 10,
    "save_steps": 10,
    "eval_steps": 10,
    "save_total_limit": 3,
    "load_best_model_at_end": true,
    "metric_for_best_model": "eval_loss",
    "greater_is_better": false,
    "early_stopping_patience": 3,
    "early_stopping_threshold": 0.0
  },
  "demo_generation": {
    "batch_size": 2,
    "max_new_tokens": 192,
    "temperature": 0.7,
    "top_p": 0.9,
    "do_sample": true,
    "repetition_penalty": 1.05
  }
}
